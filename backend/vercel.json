{
  "version": 2,
  "buildCommand": "npm install",
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "ADMIN_USERNAME": "@admin_username",
    "ADMIN_PASSWORD_HASH": "@admin_password_hash",
    "JWT_SECRET": "@jwt_secret",
    "NODE_ENV": "production"
  }
}
