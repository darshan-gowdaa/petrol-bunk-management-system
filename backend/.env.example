# Backend Environment Variables - Copy to .env and fill in actual values

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/petrol-bunk?retryWrites=true&w=majority

# Authentication Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=<generate using bcrypt>
JWT_SECRET=<generate a strong secret key>
JWT_EXPIRES_IN=1h

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Vercel Deployment
VITE_API_URL=https://your-backend.vercel.app/api
