{
  "version": 2,
  "projectSettings": {
    "framework": null
  },
  "buildCommand": "npm run build --prefix frontend",
  "installCommand": "npm install --prefix backend && npm install --prefix frontend",
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/_/backend/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
